# Локальные ключи для scripts/dev-server.mjs (скопируйте в .env — он в .gitignore).
# Личные ключи из приложения (Настройки → «Карточки из YouTube») имеют приоритет.

# Supadata (supadata.ai) — транскрипт YouTube (опционально для dev без ключа в UI)
SUPADATA_API_KEY=

# Google AI Studio (aistudio.google.com) — генерация карточек
GEMINI_API_KEY=

# Опционально: явное имя модели вместо алиаса gemini-flash-latest
# GEMINI_MODEL=

# Groq (console.groq.com) — резерв генерации карточек
GROQ_API_KEY=
