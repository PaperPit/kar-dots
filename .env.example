# Локальные ключи для scripts/dev-server.mjs (скопируйте в .env — он в .gitignore).
# Все опциональны: ключи, указанные в приложении (Настройки → «Карточки из YouTube»),
# имеют приоритет и работают без .env.

# Google AI Studio (aistudio.google.com) — основной провайдер генерации карточек
GEMINI_API_KEY=

# Опционально: явное имя модели вместо алиаса gemini-flash-latest
# GEMINI_MODEL=

# Groq (console.groq.com) — резерв генерации + распознавание речи без субтитров
GROQ_API_KEY=
