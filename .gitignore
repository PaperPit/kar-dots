# Локальные ключи Supabase (скопируйте config.example.js → config.js)
js/config.js

# Локальные переменные окружения (API-ключи) — не коммитить!
.env

# Зависимости и сборка
node_modules/

# ОС и редактор
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
.cursor/

# Локальные артефакты AI/дизайн-агентов и аналитики
.interface-design/
opencode.json
outputs/

# Генерируется для Capacitor командой npm run ios:prepare
www/

# Артефакты E2E-тестов
test-results/
playwright-report/

# Graphify
graphify-out/

# Исходники для scripts/build-vocab-packs.py (скачиваются отдельно)
scripts/data/

# Резервная копия альтернативной реализации YouTube-импорта (можно удалить после ревью)
_backup_alt_youtube_impl/
_to_delete/

# Сборка TypeScript: компилируется на место в js/ — игнорируем .js рядом с .ts,
# но оставляем исходники vendor (.mjs) и config.example.js
js/**/*.js
!js/vendor/
!js/vendor/*.mjs
!js/config.example.js
*.tsbuildinfo

# Прод-бандл (esbuild -> dist/). Локальные ключи config.js уже игнорируются выше.
dist/
